{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",

    "isolatedModules": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "baseUrl": "src",
    "skipLibCheck": true,
    "typeRoots": [ "./types", "./node_modules/@types" ],
    "resolveJsonModule": true,

    "paths": {
      "mod.json": [ "../mod.json" ]
    }
  },
  "include": [ "src", "types" ]
}
